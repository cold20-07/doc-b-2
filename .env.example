# Frontend Environment Variables
# Add these in Netlify: Site settings → Environment variables

# Google Apps Script Webhook URL (required)
# Get this from: Apps Script → Deploy → Web app URL
REACT_APP_GOOGLE_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Razorpay Key ID (required for payments)
# Get this from: Razorpay Dashboard → Settings → API Keys
# Use test key (rzp_test_) for testing, live key (rzp_live_) for production
REACT_APP_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID

# IMPORTANT: After adding these variables in Netlify:
# 1. Go to Deploys tab
# 2. Click "Trigger deploy" → "Deploy site"
# 3. Environment variables are baked into build at deploy time
